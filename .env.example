# Porta do servidor web do monitor
PORT=3030

# Diretório raiz para buscar projetos do Aider CLI (Padrão: ~/src)
# PROJECTS_ROOT=~/src

# Lista separada por vírgulas de pastas adicionais contendo arquivos de conversas (.db)
# Útil para consolidar logs de outras máquinas sincronizadas via nuvem ou rede
# ADDITIONAL_CONVERSATIONS_DIRS=~/conversations_laptop,~/conversations_desktop
